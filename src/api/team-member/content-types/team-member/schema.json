{
  "kind": "collectionType",
  "collectionName": "team_members",
  "info": {
    "singularName": "team-member",
    "pluralName": "team-members",
    "displayName": "Team Member"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "description": {
      "type": "string",
      "required": true
    },
    "photos": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": [
        "images",
        "videos",
        "audios"
      ]
    },
    "address": {
      "type": "string",
      "required": false
    },
    "languages": {
      "type": "component",
      "component": "shared.language",
      "repeatable": true
    },
    "portfolioLink": {
      "type": "string",
      "required": false
    },
    "experiences": {
      "type": "component",
      "component": "shared.work-experience",
      "repeatable": true,
      "required": false
    },
    "educations": {
      "type": "component",
      "component": "shared.education",
      "repeatable": true,
      "required": false
    },
    "skills": {
      "type": "component",
      "component": "shared.skill",
      "repeatable": true,
      "required": false
    },
    "socmedItems": {
      "type": "component",
      "component": "shared.socmed-card",
      "repeatable": true,
      "required": false
    },
    "project_assignments": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::project-assignment.project-assignment",
      "mappedBy": "team_member"
    }
  }
}
